    "report": "node scripts/generate-dashboard.js && playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.3",
    "dotenv": "^16.4.7",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
